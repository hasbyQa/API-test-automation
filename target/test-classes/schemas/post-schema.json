{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Single Post Response Schema",
  "description": "Validates the structure of GET /posts/{id} response",
  "type": "object",
  "required": ["userId", "id", "title", "body"],
  "properties": {
    "userId": {
      "type": "integer"
    },
    "id": {
      "type": "integer"
    },
    "title": {
      "type": "string"
    },
    "body": {
      "type": "string"
    }
  },
  "additionalProperties": false
}